root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 2

# shfmt options
binary_next_line = true
switch_case_indent = true
space_redirects = false
function_next_line = false
